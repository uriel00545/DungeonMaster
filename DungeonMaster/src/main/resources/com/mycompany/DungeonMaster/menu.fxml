<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.geometry.Insets?>

<VBox alignment="CENTER" spacing="20.0" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="com.mycompany.DungeonMaster.controller.MenuController">
    
   <children>
      
      <Label text="DUNGEON MASTER" />
      <Button fx:id="play" text="jogar" onAction="#jogar"/>
      <Button fx:id="close" text="fechar jogo " onAction="#fecharJogo"/>
      
   </children>
   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
   </padding>
</VBox>
